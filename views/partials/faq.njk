<section class="faq-section">
  <h2>{{ title }}</h2>
  <div class="faq-grid">
    {% for item in items %}
    <div class="faq-item">
      <details>
        <summary>{{ item.question }}</summary>
        <div class="faq-body">{{ item.answer }}</div>
      </details>
    </div>
    {% endfor %}
  </div>
</section>
