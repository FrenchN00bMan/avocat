<section class="cta-band">
  <div class="container">
    <h2>{{ title }}</h2>
    <p>{{ text }}</p>
    <div class="cta-actions">
      <a href="/contact/" class="btn-primary-light">{{ buttonLabel or 'Prendre rendez-vous' }}</a>
      <a href="tel:{{ site.phoneHref }}" class="btn-phone">{{ site.phone }}</a>
    </div>
  </div>
</section>
