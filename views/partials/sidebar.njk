<aside class="sidebar">
  <div class="sidebar-card sidebar-cta">
    <h4>{{ ctaTitle }}</h4>
    <p>{{ ctaText }}</p>
    <a href="/contact/" class="btn-primary">{{ ctaButton or 'Prendre rendez-vous' }}</a>
  </div>
  <div class="sidebar-card">
    <h4>Contact direct</h4>
    <div class="contact-info">
      <div><a href="tel:{{ site.phoneHref }}">{{ site.phone }}</a></div>
      <div><a href="mailto:{{ site.email }}">{{ site.email }}</a></div>
      <div>{{ site.address }}<br>{{ site.postalCode }} {{ site.city }}</div>
    </div>
  </div>
  {% if links and links.length %}
  <div class="sidebar-card">
    <h4>{{ linksTitle or 'Domaines liés' }}</h4>
    <ul class="sidebar-links">
      {% for link in links %}
      <li><a href="{{ link.href }}">{{ link.label }}</a></li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
  {% if notes and notes.length %}
  <div class="sidebar-card">
    <h4>{{ notesTitle or 'À savoir' }}</h4>
    {% for note in notes %}
    <p class="sidebar-note">{{ note | safe }}</p>
    {% endfor %}
  </div>
  {% endif %}
</aside>
