{% extends "layouts/base.njk" %}

{% block content %}
<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Accueil</a> › Admin</div>
    <h1>Connexion admin</h1>
    <p class="lead">Accès au back-office des articles du cabinet.</p>
  </div>
</section>
<div class="container" style="padding:4rem 2rem 6rem; max-width:760px;">
  <form method="post" action="/admin/login" class="contact-form-block">
    {% if error %}<p style="color:#8b1e1e; font-weight:600;">{{ error }}</p>{% endif %}
    <div class="form-group">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required>
    </div>
    <div class="form-group">
      <label for="password">Mot de passe</label>
      <input id="password" name="password" type="password" required>
    </div>
    <button class="form-submit" type="submit">Se connecter</button>
  </form>
</div>
{% endblock %}
