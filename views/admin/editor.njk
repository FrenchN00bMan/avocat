{% extends "layouts/base.njk" %}

{% block content %}
<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Accueil</a> › <a href="/admin/dashboard">Admin</a> › Éditeur</div>
    <h1>{{ article and "Éditer l'article" or "Nouvel article" }}</h1>
    <p class="lead">Le contenu est enregistré en Markdown dans le dossier du projet.</p>
  </div>
</section>
<div class="container" style="padding:4rem 2rem 6rem; max-width:980px;">
  <form method="post" action="{{ article and ('/admin/articles/' ~ article.slug) or '/admin/articles' }}" class="contact-form-block">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1.25rem; flex-wrap:wrap;">
      <div style="font-size:0.85rem; color:var(--text-mid);">
        Statut actuel :
        <strong style="color:var(--navy);">{{ article.published and 'Publié' or 'Brouillon' }}</strong>
      </div>
      {% if article and article.slug and article.published %}
      <a href="/actualites/{{ article.slug }}/" class="btn-secondary">Voir la page publique</a>
      {% endif %}
    </div>
    <div class="form-row">
      <div class="form-group"><label for="title">Titre</label><input id="title" name="title" type="text" required value="{{ article.title if article else '' }}"></div>
      <div class="form-group"><label for="slug">Slug</label><input id="slug" name="slug" type="text" value="{{ article.slug if article else '' }}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label for="date">Date</label><input id="date" name="date" type="date" value="{{ article.date if article else '' }}"></div>
      <div class="form-group"><label for="category">Catégorie</label><input id="category" name="category" type="text" value="{{ article.category if article else 'Droit du travail' }}"></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label for="readingTime">Temps de lecture</label><input id="readingTime" name="readingTime" type="text" value="{{ article.readingTime if article else '5 min' }}"></div>
      <div class="form-group">
        <label for="published">Publication</label>
        <select id="published" name="published">
          <option value="false" {% if article and not article.published %}selected{% endif %}>Brouillon</option>
          <option value="true" {% if article and article.published %}selected{% endif %}>Publié</option>
        </select>
      </div>
    </div>
    <div class="form-group"><label for="description">Description SEO</label><textarea id="description" name="description">{{ article.description if article else '' }}</textarea></div>
    <div class="form-group"><label for="summary">Résumé</label><textarea id="summary" name="summary">{{ article.summary if article else '' }}</textarea></div>
    <div class="form-group"><label for="content">Contenu Markdown</label><textarea id="content" name="content" style="min-height:420px;">{{ article.content if article else '' }}</textarea></div>
    <div style="display:flex; gap:1rem; flex-wrap:wrap;">
      <button type="submit" class="form-submit" style="width:auto; min-width:220px;">Enregistrer</button>
      <a href="/admin/dashboard" class="btn-secondary">Retour dashboard</a>
    </div>
  </form>
  {% if article %}
  <form method="post" action="/admin/articles/{{ article.slug }}/delete" style="margin-top:1rem;">
    <button type="submit" class="btn-secondary">Supprimer l'article</button>
  </form>
  {% endif %}
</div>
{% endblock %}
